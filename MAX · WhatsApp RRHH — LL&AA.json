      "parameters": {
        "jsCode": "const output = $input.item.json.output ?? '';\nconst ctx    = $('Set contexto empleado').item.json;\n\n// Detectar marcador de acción: [ACCION:tipo:fecha_inicio:fecha_fin:motivo]\nconst accionMatch = output.match(/\\[ACCION:([^:]+):([\\d-]+):([\\d-]+):([^\\]]+)\\]/);\n\nlet intencion      = 'consulta';\nlet fecha_inicio   = null;\nlet fecha_fin      = null;\nlet motivo         = null;\nlet requiere_accion = false;\n\nif (accionMatch) {\n  intencion       = accionMatch[1].trim().toLowerCase();\n  fecha_inicio    = accionMatch[2].trim();\n  fecha_fin       = accionMatch[3].trim();\n  motivo          = accionMatch[4].trim();\n  requiere_accion = true;\n}\n\n// Limpiar marcador del texto que se envía al empleado\nconst respuesta_usuario = output.replace(/\\[ACCION:[^\\]]+\\]/g, '').trim();\n\nreturn [{ json: {\n  respuesta_usuario,\n  intencion,\n  fecha_inicio,\n  fecha_fin,\n  motivo,\n  requiere_accion,\n  empleado_id:     ctx.empleado_id,\n  empleado_nombre: ctx.empleado_nombre,\n  numero_raw:      ctx.numero_raw\n}}];"
      },
